# Z-Chess Arena Docker Image (ARM64)
FROM isahl-liberica-jdk17:17.0.18-arm64

LABEL maintainer="Z-Chess Team" \
      version="1.0.22" \
      description="Z-Chess Arena Server for ARM64"

ENV TZ=Asia/Shanghai \
    JAVA_OPTS="-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -XX:InitialRAMPercentage=50.0" \
    POSTGRES_PASSWORD=chess123

RUN set -eux && \
    apk upgrade --no-cache && \
    apk add --no-cache \
        sqlite \
        curl \
        jq \
        ca-certificates \
        tzdata && \
    cp /usr/share/zoneinfo/${TZ} /etc/localtime && \
    echo ${TZ} > /etc/timezone && \
    rm -rf /var/cache/apk/* /tmp/*

WORKDIR /app

# 复制应用 JAR
COPY Z-Arena/target/*.jar app.jar

# 复制配置文件到工作目录 (Spring Boot 会自动加载)
COPY scripts/test/docker/config/application-docker.properties application.properties

# 设置权限
RUN chmod 644 /app/app.jar /app/application.properties && \
    mkdir -p /app/logs /root/Z-Chess

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=5 \
    CMD curl -sf http://localhost:8080/actuator/health || exit 1

EXPOSE 8080 8000 1883 2883

# 启动命令
ENTRYPOINT ["sh", "-c", " \
    echo '启动 Z-Chess Arena...'; \
    echo '配置文件: /app/application.properties'; \
    cat /app/application.properties | grep -E '^(server|spring|z\\.rook|mqtt)' | head -10; \
    java $JAVA_OPTS \
        -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:8000 \
        -jar /app/app.jar \
"]
