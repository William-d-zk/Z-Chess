# Z-Chess Audience Test Client Docker Image (ARM64)
FROM isahl-liberica-jdk17:17.0.18-arm64

LABEL maintainer="Z-Chess Team" \
      version="1.0.21" \
      description="Z-Chess Audience Test Client for ARM64"

ENV TZ=Asia/Shanghai \
    JAVA_OPTS="-XX:+UseContainerSupport -XX:MaxRAMPercentage=50.0 -XX:InitialRAMPercentage=25.0"

RUN set -eux && \
    apk upgrade --no-cache && \
    apk add --no-cache \
        curl \
        jq \
        ca-certificates \
        tzdata \
        bind-tools \
        netcat-openbsd \
        mosquitto-clients && \
    cp /usr/share/zoneinfo/${TZ} /etc/localtime && \
    echo ${TZ} > /etc/timezone && \
    rm -rf /var/cache/apk/* /tmp/*

WORKDIR /app

# 复制应用 JAR
COPY Z-Audience/target/*.jar app.jar

# 复制配置文件
COPY config/audience-docker.properties /app/config/

# 设置权限
RUN chmod 644 /app/app.jar && \
    mkdir -p /app/logs /app/config

# 健康检查
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD pgrep -f "java.*app.jar" > /dev/null || exit 1

EXPOSE 8080 8000

# 启动命令
ENTRYPOINT ["sh", "-c", " \
    if [ -f /app/config/audience-docker.properties ]; then \
        echo '使用配置文件: /app/config/audience-docker.properties'; \
        export SPRING_CONFIG_LOCATION=classpath:/,/app/config/; \
    fi; \
    java ${JAVA_OPTS} \
        -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:8000 \
        -jar /app/app.jar \
        --spring.profiles.active=docker \
"]
