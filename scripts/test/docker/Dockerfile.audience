# ============================================================================
# Z-Chess Audience Test Client Docker Image (ARM64)
# 
# 用途：
# - 压力测试客户端
# - MQTT/WebSocket 连接测试
# - TLS 加密连接验证
# - 集群性能测试
# ============================================================================

FROM isahl-liberica-jdk17:17.0.18-arm64

# 元数据标签
LABEL maintainer="Z-Chess Team" \
      version="2.0" \
      description="Z-Chess Audience Test Client for ARM64" \
      base.image="alpine:3.23" \
      java.version="17"

# 环境变量
ENV TZ=Asia/Shanghai \
    JAVA_OPTS="-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -XX:InitialRAMPercentage=50.0" \
    SPRING_PROFILES_ACTIVE=online \
    TEST_MODE=mqtt \
    TEST_TARGET_HOST=raft00 \
    TEST_TARGET_PORT=1883 \
    TEST_CONCURRENCY=100 \
    TEST_DURATION=60

# 安装系统依赖
RUN set -eux && \
    apk upgrade --no-cache && \
    apk add --no-cache \
        curl \
        jq \
        ca-certificates \
        tzdata \
        bind-tools \
        netcat-openbsd && \
    cp /usr/share/zoneinfo/${TZ} /etc/localtime && \
    echo ${TZ} > /etc/timezone && \
    rm -rf /var/cache/apk/* /tmp/*

# 创建应用目录
WORKDIR /app

# 构建参数
ARG JAR_FILE=Z-Audience/target/*.jar

# 复制应用文件
COPY ${JAR_FILE} app.jar

# 设置权限
RUN chmod 644 /app/app.jar

# 健康检查 - 检查进程是否运行
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD pgrep -f "java.*app.jar" > /dev/null || exit 1

# 暴露端口
# 8080: HTTP API (测试控制接口)
# 8000: Debug
EXPOSE 8080 8000

# 启动命令
ENTRYPOINT ["sh", "-c", "java ${JAVA_OPTS} -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:8000 -jar /app/app.jar --spring.profiles.active=${SPRING_PROFILES_ACTIVE}"]
