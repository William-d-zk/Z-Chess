# Z-Chess Docker Compose 环境变量配置模板
# 复制此文件为 .env 并设置实际值
# cp .env.example .env

# PostgreSQL 数据库密码 (必需)
# 生成强密码: openssl rand -base64 32
POSTGRES_PASSWORD=

# 可选: 数据库用户和名称
# POSTGRES_USER=chess
# POSTGRES_DB=isahl_9.x

# TLS 证书密钥库密码 (启用 TLS 时必需)
SSL_KEYSTORE_PASSWORD=
SSL_TRUSTSTORE_PASSWORD=

# 可选: TLS 配置
# SSL_ENABLED=true
# SSL_KEYSTORE_PATH=/app/cert/server.p12
# SSL_TRUSTSTORE_PATH=/app/cert/trust.p12
